; SRT Meeting App — OBS Plugin Installer
; Inno Setup 6+ script (per-user, no admin required, modern)
; This file is processed by Package-Windows.ps1 — placeholder format: __VARNAME__

#define MyAppName "__PLUGIN_DISPLAY_NAME__"
#define MyAppNameShort "__PLUGIN_NAME__"
#define MyAppVersion "__PLUGIN_VERSION__"
#define MyAppPublisher "__PLUGIN_AUTHOR__"
#define MyAppURL "__PLUGIN_WEBSITE__"
#define MyAppArch "__TARGET_ARCH__"

; BUILD_DIR and OUTPUT_DIR are passed via ISCC /dBUILD_DIR=... /dOUTPUT_DIR=...
#ifndef BUILD_DIR
  #define BUILD_DIR "."
#endif
#ifndef OUTPUT_DIR
  #define OUTPUT_DIR "."
#endif

#define MyAppOutput "{#MyAppNameShort}-{#MyAppVersion}-windows-{#MyAppArch}"

[Setup]
AppId={{E8A4B8C0-2E5F-4A7D-9B3C-1F6D8A2E5C7B}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
AppSupportURL={#MyAppURL}
AppUpdatesURL={#MyAppURL}
VersionInfoVersion={#MyAppVersion}
DefaultDirName={userappdata}\obs-studio\plugins\{#MyAppNameShort}
OutputDir={#OUTPUT_DIR}
OutputBaseFilename={#MyAppOutput}
Compression=lzma2/ultra64
SolidCompression=yes
UninstallDisplayName={#MyAppName} {#MyAppVersion}
UninstallDisplayIcon={app}\bin\64bit\{#MyAppNameShort}.dll
DisableProgramGroupPage=yes
DisableDirPage=yes
DisableReadyPage=yes
PrivilegesRequired=lowest
ShowLanguageDialog=no
LanguageDetectionMethod=none
CreateUninstallRegKey=yes
CloseApplications=no
MinVersion=10.0

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Files]
Source: "{#BUILD_DIR}\bin\64bit\{#MyAppNameShort}.dll"; DestDir: "{app}\bin\64bit"; Flags: ignoreversion
Source: "{#BUILD_DIR}\bin\64bit\{#MyAppNameShort}.pdb"; DestDir: "{app}\bin\64bit"; Flags: ignoreversion skipifsourcedoesntexist
Source: "{#BUILD_DIR}\data\*"; DestDir: "{app}\data"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\{cm:UninstallProgram,{#MyAppName}}"; Filename: "{uninstallexe}"

[Run]
Filename: "{cmd}"; Parameters: "/C echo SRT Meeting App plugin installed successfully."; Flags: runhidden

[Code]
function IsAppAlreadyInstalled(const AppId: string): Boolean;
var
  sUninstallPath: string;
begin
  Result := RegQueryStringValue(HKCU, 'Software\Microsoft\Windows\CurrentVersion\Uninstall\' + AppId, 'UninstallString', sUninstallPath);
end;

function InitializeSetup: Boolean;
begin
  Result := True;
end;

procedure CurStepChanged(CurStep: TSetupStep);
begin
  if CurStep = ssPostInstall then
  begin
  end;
end;
