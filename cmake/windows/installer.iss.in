; SRT Meeting App — OBS Plugin Installer
; Inno Setup 6+ script (per-user, no admin required, modern)
; This file is processed by Package-Windows.ps1 — placeholder format: __VARNAME__

; BUILD_DIR and OUTPUT_DIR are passed via ISCC /dBUILD_DIR=... /dOUTPUT_DIR=...
#ifndef BUILD_DIR
  #define BUILD_DIR "."
#endif
#ifndef OUTPUT_DIR
  #define OUTPUT_DIR "."
#endif

[Setup]
AppId={{E8A4B8C0-2E5F-4A7D-9B3C-1F6D8A2E5C7B}
AppName=__PLUGIN_DISPLAY_NAME__
AppVersion=__PLUGIN_VERSION__
AppPublisher=__PLUGIN_AUTHOR__
AppPublisherURL=__PLUGIN_WEBSITE__
AppSupportURL=__PLUGIN_WEBSITE__
AppUpdatesURL=__PLUGIN_WEBSITE__
VersionInfoVersion=__PLUGIN_VERSION__
DefaultDirName={userappdata}\obs-studio\plugins\__PLUGIN_NAME__
OutputDir={#OUTPUT_DIR}
OutputBaseFilename=__OUTPUT_NAME__
Compression=lzma2/ultra64
SolidCompression=yes
UninstallDisplayName=__PLUGIN_DISPLAY_NAME__ __PLUGIN_VERSION__
UninstallDisplayIcon={app}\bin\64bit\__PLUGIN_NAME__.dll
DisableProgramGroupPage=yes
DisableDirPage=yes
DisableReadyPage=yes
PrivilegesRequired=lowest
ShowLanguageDialog=no
LanguageDetectionMethod=none
CreateUninstallRegKey=yes
CloseApplications=no
MinVersion=10.0

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Files]
Source: "{#BUILD_DIR}\bin\64bit\__PLUGIN_NAME__.dll"; DestDir: "{app}\bin\64bit"; Flags: ignoreversion
Source: "{#BUILD_DIR}\bin\64bit\__PLUGIN_NAME__.pdb"; DestDir: "{app}\bin\64bit"; Flags: ignoreversion skipifsourcedoesntexist
Source: "{#BUILD_DIR}\data\*"; DestDir: "{app}\data"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\{cm:UninstallProgram,__PLUGIN_DISPLAY_NAME__}"; Filename: "{uninstallexe}"

[Run]
Filename: "{cmd}"; Parameters: "/C echo __PLUGIN_DISPLAY_NAME__ plugin installed successfully."; Flags: runhidden

[Code]
function IsAppAlreadyInstalled(const AppId: string): Boolean;
var
  sUninstallPath: string;
begin
  Result := RegQueryStringValue(HKCU, 'Software\Microsoft\Windows\CurrentVersion\Uninstall\' + AppId, 'UninstallString', sUninstallPath);
end;

function InitializeSetup: Boolean;
begin
  Result := True;
end;

procedure CurStepChanged(CurStep: TSetupStep);
begin
  if CurStep = ssPostInstall then
  begin
  end;
end;
